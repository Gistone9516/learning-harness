# v5 study-bot 환경 설정 템플릿
# 이 파일을 .env 로 복사한 뒤 값을 채운다.
# .env 는 절대 커밋하지 않는다(토큰 노출 위험).

# ─────────────────────────────────────────
# 필수 4키 (미기입 시 봇 구동 거부)
# ─────────────────────────────────────────

# Discord 봇 토큰. 개발자 포털(https://discord.com/developers/applications)에서 발급.
# discord-bridge 와 별개 앱·토큰을 써야 한다.
DISCORD_BOT_TOKEN=

# 학습 전용 서버(길드)의 ID. Discord 앱에서 서버 아이콘 우클릭 > ID 복사.
DISCORD_GUILD_ID=

# 봇이 기본으로 사용할 채널 ID. 원하는 채널 우클릭 > ID 복사.
DISCORD_CHANNEL_ID=

# 학습 명령을 내릴 수 있는 Discord 사용자 ID. 본인 프로필 우클릭 > ID 복사.
DISCORD_ALLOWED_USER_ID=

# ─────────────────────────────────────────
# 선택 키 (기본값 있음, 생략 가능)
# ─────────────────────────────────────────

# 봇 응답 출력 언어. 기본값: ko
# USER_LANG=ko

# 기본 마운트 콘텐츠 폴더 절대경로. 미지정 시 봇을 실행한 cwd 를 사용.
# MOUNT=C:\Users\USER\Desktop\내과목폴더
