# v5 study-bot environment configuration template
# Copy this file to .env and fill in the values.
# Never commit .env (token exposure risk).

# ─────────────────────────────────────────
# Required keys (bot refuses to start if missing)
# ─────────────────────────────────────────

# Discord bot token. Issued from the developer portal (https://discord.com/developers/applications).
# Must use a separate app and token from discord-bridge.
DISCORD_BOT_TOKEN=

# ID of the study-dedicated server (guild). Right-click the server icon in Discord > Copy ID.
DISCORD_GUILD_ID=

# Channel ID the bot uses by default. Right-click the desired channel > Copy ID.
DISCORD_CHANNEL_ID=

# Discord user ID allowed to issue study commands. Right-click your profile > Copy ID.
DISCORD_ALLOWED_USER_ID=

# ─────────────────────────────────────────
# Optional keys (defaults provided, can be omitted)
# ─────────────────────────────────────────

# Bot response output language. Default: ko
# USER_LANG=ko

# AI model ids (single source; swap here, not in code/config).
# AI_MODEL = main model for grading / practice / conversation.
# AI_MODEL_EXPLAIN = model for the per-card concept explanation thread (cheaper, e.g. haiku).
# AI_MODEL=claude-sonnet-4-6
# AI_MODEL_EXPLAIN=claude-haiku-4-5-20251001

# Absolute path to the default mounted content folder. Uses the cwd where the bot was launched if unset.
# MOUNT=C:\Users\USER\Desktop\MySubjectFolder

# ─────────────────────────────────────────
# Web AI bridge (bot/ai_server.py) — only if you run the web frontend's AI features
# ─────────────────────────────────────────
# Shared token the web client must send (Authorization: Bearer <token> or X-AI-Token header).
# The server refuses to start without it. Use a long random value; never put it in the web bundle.
# AI_SERVER_TOKEN=
# Bind host/port (default 127.0.0.1:8765). Keep localhost; expose remotely via a tunnel only.
# AI_SERVER_HOST=127.0.0.1
# AI_SERVER_PORT=8765
# CORS allowed origin for the web client (default *; the token gates every request anyway).
# AI_SERVER_ORIGIN=*
