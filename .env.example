# v5 study-bot environment configuration template
# Copy this file to .env and fill in the values.
# Never commit .env (token exposure risk).

# ─────────────────────────────────────────
# Required keys (bot refuses to start if missing)
# ─────────────────────────────────────────

# Discord bot token. Issued from the developer portal (https://discord.com/developers/applications).
# Must use a separate app and token from discord-bridge.
DISCORD_BOT_TOKEN=

# ID of the study-dedicated server (guild). Right-click the server icon in Discord > Copy ID.
DISCORD_GUILD_ID=

# Channel ID the bot uses by default. Right-click the desired channel > Copy ID.
DISCORD_CHANNEL_ID=

# Discord user ID allowed to issue study commands. Right-click your profile > Copy ID.
DISCORD_ALLOWED_USER_ID=

# ─────────────────────────────────────────
# Optional keys (defaults provided, can be omitted)
# ─────────────────────────────────────────

# Bot response output language. Default: ko
# USER_LANG=ko

# Absolute path to the default mounted content folder. Uses the cwd where the bot was launched if unset.
# MOUNT=C:\Users\USER\Desktop\MySubjectFolder
